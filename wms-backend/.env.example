# ===================================
# Giving Out WMS — Environment Variables
# ===================================

# Database — Supabase PostgreSQL
DATABASE_URL="postgresql://postgres.xxxx:password@aws-0-us-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.xxxx:password@aws-0-us-west-1.pooler.supabase.com:5432/postgres"

# Auth — JWT
JWT_SECRET="super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="24h"

# Server
PORT=3001
NODE_ENV="development"

# CORS — Dominios permitidos (separados por coma)
ALLOWED_ORIGINS="https://wms-giving-out.vercel.app"

# Email — Para OTP (Nodemailer)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="wms@givingout.mx"
SMTP_PASS="app-password-here"
SMTP_FROM="WMS Giving Out <wms@givingout.mx>"

